{
  "name": "@canvas-courseware/vue",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src"],
  "dependencies": {
    "@canvas-courseware/core": "workspace:*",
    "@canvas-courseware/fabric": "workspace:*"
  },
  "peerDependencies": {
    "@arco-design/web-vue": "^2.57.0",
    "vue": "^3.5.0"
  },
  "scripts": {
    "build": "vite build -c vite.config.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  }
}

{
  "version": "1.0.0",
  "meta": {
    "id": "courseware-demo",
    "title": "Canvas Courseware Demo"
  },
  "slides": [
    {
      "id": "slide-1",
      "name": "Intro",
      "size": {
        "width": 1280,
        "height": 720
      },
      "background": {
        "fill": "#F5F7FB",
        "image": {
          "src": "https://example.com/demo-background.png",
          "fit": "cover"
        }
      },
      "nodes": [
        {
          "id": "node-title",
          "type": "text",
          "name": "Title",
          "x": 96,
          "y": 80,
          "width": 640,
          "height": 72,
          "rotation": 0,
          "opacity": 1,
          "visible": true,
          "locked": false,
          "props": {
            "text": "Fabric MVP",
            "fontSize": 48,
            "color": "#172033",
            "fontWeight": 700,
            "textAlign": "left"
          }
        },
        {
          "id": "node-accent",
          "type": "rect",
          "name": "Accent Card",
          "x": 96,
          "y": 190,
          "width": 420,
          "height": 180,
          "rotation": 0,
          "opacity": 1,
          "visible": false,
          "locked": false,
          "props": {
            "fill": "#DCE8FF",
            "stroke": "#4B7BE5",
            "strokeWidth": 2,
            "radius": 20
          }
        },
        {
          "id": "node-cover",
          "type": "image",
          "name": "Cover Image",
          "x": 780,
          "y": 140,
          "width": 320,
          "height": 320,
          "rotation": 0,
          "opacity": 1,
          "visible": false,
          "locked": false,
          "props": {
            "src": "https://example.com/demo-cover.png",
            "alt": "Demo cover",
            "objectFit": "cover"
          }
        }
      ],
      "timeline": {
        "steps": [
          {
            "id": "step-1",
            "name": "Show accent",
            "trigger": {
              "type": "page-click"
            },
            "actions": [
              {
                "id": "action-1",
                "type": "show-node",
                "targetId": "node-accent",
                "animationId": "animation-fade-accent"
              }
            ]
          },
          {
            "id": "step-2",
            "name": "Show cover",
            "trigger": {
              "type": "auto",
              "delayMs": 400
            },
            "actions": [
              {
                "id": "action-2",
                "type": "show-node",
                "targetId": "node-cover",
                "animationId": "animation-slide-cover"
              }
            ]
          }
        ],
        "animations": [
          {
            "id": "animation-fade-accent",
            "targetId": "node-accent",
            "kind": "fade",
            "durationMs": 300,
            "easing": "ease-out"
          },
          {
            "id": "animation-slide-cover",
            "targetId": "node-cover",
            "kind": "slide-up",
            "durationMs": 450,
            "easing": "ease-out",
            "offsetY": 32
          }
        ]
      }
    },
    {
      "id": "slide-2",
      "name": "Summary",
      "size": {
        "width": 1280,
        "height": 720
      },
      "background": {
        "fill": "#FFFFFF"
      },
      "nodes": [
        {
          "id": "node-summary",
          "type": "text",
          "name": "Summary Text",
          "x": 96,
          "y": 100,
          "width": 720,
          "height": 140,
          "rotation": 0,
          "opacity": 1,
          "visible": true,
          "locked": false,
          "props": {
            "text": "Schema and events are shared across editor and player.",
            "fontSize": 32,
            "color": "#172033",
            "lineHeight": 1.4
          }
        }
      ],
      "timeline": {
        "steps": [],
        "animations": []
      }
    }
  ]
}
